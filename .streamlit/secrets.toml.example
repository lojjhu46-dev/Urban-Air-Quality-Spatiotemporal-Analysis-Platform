# Example only. Copy this to .streamlit/secrets.toml for local use.
# Do not commit .streamlit/secrets.toml with real values.

# Optional: override the default local dataset path.
data_path = "data/processed/beijing_aq.parquet"

# Historical Data Agent runs in the current Streamlit process.
agent_task_executor_mode = "thread"
agent_task_timeout_seconds = 1800
agent_task_stalled_seconds = 300

# Optional: enable DeepSeek-enhanced planning, validation, and summaries.
# deepseek_api_key = "sk-..."
# deepseek_model = "deepseek-v4-flash"
# deepseek_base_url = "https://api.deepseek.com"
