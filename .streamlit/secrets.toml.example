# Example only. Copy the relevant block into your own secrets store.
# Do not commit .streamlit/secrets.toml with real values.

# -------------------------------------------------------------------
# Local recommended mode
# -------------------------------------------------------------------
# The current project baseline is local-first. Keep these values while
# you are not running a real Supabase + external worker deployment.

data_path = "data/processed/beijing_aq.parquet"
agent_task_executor_mode = "thread"
dataset_storage_mode = "local"

# Optional: enable the historical collection agent with DeepSeek
# deepseek_api_key = "sk-"
# deepseek_model = "deepseek-v4-flash"
# deepseek_base_url = "https://api.deepseek.com"

# Optional local task timeout tuning
# agent_task_timeout_seconds = 1800
# agent_task_stalled_seconds = 300

# -------------------------------------------------------------------
# Cloud preparation notes
# -------------------------------------------------------------------
# Use this only after creating the Supabase project, running
# docs/supabase_agent_tasks.sql, creating the Storage bucket, deploying
# a worker, and passing scripts/supabase_smoke_test.py.
#
# In cloud mode:
# - Streamlit Cloud uses agent_task_executor_mode = "worker".
# - The UI only creates PENDING tasks.
# - A separate worker process claims and executes tasks.
# - Generated datasets are uploaded to Supabase Storage.

# Optional: Supabase Postgres task status and dataset index storage.
# Use the Supabase database connection string from Project Settings > Database.
# Prefer the transaction pooler URL for Streamlit Cloud deployments.
# Worker mode requires this to be configured.
# database_url = "postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Optional: dataset file storage. "local" keeps the generated parquet/csv
# on the current filesystem. "supabase" uploads generated files to
# Supabase Storage and records supabase://... URIs in dataset_index.
# dataset_storage_mode = "local"
# supabase_url = "https://<project-ref>.supabase.co"
# supabase_service_role_key = "<service-role-key>"
# supabase_storage_bucket = "aq-datasets"
# dataset_storage_cache_dir = ".cache/datasets"

# Candidate production block for Streamlit Community Cloud + Render worker:
#
# database_url = "postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"
# agent_task_executor_mode = "worker"
# dataset_storage_mode = "supabase"
# supabase_url = "https://<project-ref>.supabase.co"
# supabase_service_role_key = "<service-role-key>"
# supabase_storage_bucket = "aq-datasets"
# deepseek_api_key = "sk-..."
# deepseek_model = "deepseek-v4-flash"
# deepseek_base_url = "https://api.deepseek.com"
